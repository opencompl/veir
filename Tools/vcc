#!/usr/bin/env python3
"""VeIR compiler driver.

Compiles a C source file via VeIR, producing an executable by default.
"""

from __future__ import annotations

import argparse
import math
import re
import shutil
import struct
import subprocess
import sys
import tempfile
from pathlib import Path


BASE_TOOLS = ("clang", "opt", "mlir-translate", "mlir-opt")
VEIR_TOOLS = ("lake",)
REPO_ROOT = Path(__file__).resolve().parent.parent


# --------------------------------------------------------------------------
# TEMPORARY: rewrite decimal float literals into raw-bit hex.
#
# VeIR cannot parse decimal floating-point literals yet, so we rewrite scalar
# float attributes into the raw-bit hex form that MLIR itself already uses for
# infinities and NaNs (e.g. "0x7F800000 : f32").  MLIR both prints and parses
# this form, and the bit pattern is width-matched to the type, so the rewrite
# is exactly value-preserving.
#
# Only scalar f16/f32/f64 attributes are touched.  Elements inside dense<>
# attributes are deliberately left alone: their type follows the element list
# rather than each element, so they do not match the pattern below.
#
# Delete this section and its single call in compile_to_mlir() once VeIR parses
# floats directly.
# --------------------------------------------------------------------------

_FLOAT_PACK = {"f16": "<e", "f32": "<f", "f64": "<d"}

# The 0x alternative matches literals that are *already* raw bits and passes
# them through untouched.  It must come first: without it, a hex pattern such
# as "0x41E00000 : f32" contains the substring "1E00000", which would
# otherwise be mistaken for a decimal literal in exponent notation.
_FLOAT_ATTR = re.compile(
    rb"""(?<![\w.])(
          0x[0-9A-Fa-f]+                        # already raw bits
        | [-+]?(?: \d+\.\d*(?:[eE][-+]?\d+)?    # 1.5, 1.500000e+00
                 | \d+[eE][-+]?\d+ )            # 1e10
        )\s*:\s*(f16|f32|f64)\b""",
    re.VERBOSE,
)


def float_to_raw_bits(literal: str, ty: str) -> str:
    """Return the exact IEEE-754 bit pattern of a decimal literal at width ty.

    float() is correctly rounded to binary64 and struct.pack narrows exactly,
    so no precision is lost for any literal MLIR emits.
    """
    value = float(literal)
    try:
        packed = struct.pack(_FLOAT_PACK[ty], value)
    except OverflowError:
        # Out of range for the target width; IEEE-754 rounds these to infinity.
        packed = struct.pack(_FLOAT_PACK[ty], math.copysign(math.inf, value))
    return f"0x{int.from_bytes(packed, 'little'):0{2 * len(packed)}X}"


def rewrite_floats_as_raw_bits(mlir: bytes) -> bytes:
    def replace(m: re.Match[bytes]) -> bytes:
        literal, ty = m.group(1).decode(), m.group(2).decode()
        if literal.lower().startswith("0x"):
            return m.group(0)
        return f"{float_to_raw_bits(literal, ty)} : {ty}".encode()

    return _FLOAT_ATTR.sub(replace, mlir)


def check_tools(tools: tuple[str, ...]) -> None:
    missing = [t for t in tools if shutil.which(t) is None]
    if missing:
        sys.exit(f"vcc: required tool(s) not found in PATH: {', '.join(missing)}")


def run(cmd: list[str], *, stdin: bytes | None = None, cwd: Path | None = None, debug: bool = False) -> bytes:
    if debug:
        print(f"+ vcc.run: {' '.join(cmd)}", file=sys.stderr)
    result = subprocess.run(cmd, input=stdin, capture_output=True, cwd=cwd)
    if result.returncode != 0:
        err = result.stderr.decode("utf-8", errors="replace")
        sys.exit(f"vcc: {cmd[0]} failed:\n{err}")
    return result.stdout


def compile_to_mlir(src: Path, veir_optimize: bool, llvm_o2: bool, debug: bool = False) -> bytes:
    with tempfile.TemporaryDirectory(delete=not debug) as tmpdir:
        tmp = Path(tmpdir)
        bc = tmp / (src.stem + ".bc")
        bc_opt = tmp / (src.stem + "-opt.bc")

        run(["clang", "-O0", "-Xclang", "-disable-O0-optnone", "-c", "-emit-llvm",
             str(src), "-o", str(bc)], debug=debug)
        if llvm_o2:
            # Run the full LLVM middle-end optimization pipeline, minus
            # autovectorization.
            run(["opt", "-O2", "-vectorize-loops=false", "-vectorize-slp=false",
                 str(bc), "-o", str(bc_opt)], debug=debug)
        else:
            # TODO -- as soon as we have our own mem2reg, stop running LLVM's
            run(["opt", "-passes=sroa", str(bc), "-o", str(bc_opt)], debug=debug)
        translated = run(["mlir-translate", "--import-llvm", str(bc_opt)], debug=debug)
        mlir = run(
            ["mlir-opt", "--mlir-print-op-generic", "--mlir-print-local-scope"],
            stdin=translated,
            debug=debug
        )
        # TEMPORARY: remove once VeIR parses decimal floats (see above).
        mlir = rewrite_floats_as_raw_bits(mlir)
        pre = tmp / (src.stem + ".mlir")
        pre.write_bytes(mlir)
        opt_cmd = ["lake", "exec", "veir-opt", "--allow-unregistered-dialect"]
        if veir_optimize:
            opt_cmd.append("-p=instcombine,dce,cse,dce")
        opt_cmd.append(str(pre))
        mlir = run(
            opt_cmd,
            cwd=REPO_ROOT,
            debug=debug
        )
        return mlir


def translate_mlir_to_llvm(mlir: bytes, src_stem: str, debug: bool = False) -> bytes:
    with tempfile.TemporaryDirectory() as tmpdir:
        path = Path(tmpdir) / (src_stem + ".mlir")
        path.write_bytes(mlir)
        return run(["mlir-translate", "--mlir-to-llvmir", str(path)], debug=debug)


def write_output(output: bytes, dst: Path | None) -> None:
    if dst is None:
        sys.stdout.buffer.write(output)
    else:
        dst.write_bytes(output)


def finish_llvm_ir(llvm_ir: bytes, dst: Path | None, emit: str, debug: bool = False) -> None:
    with tempfile.TemporaryDirectory(delete = not debug) as tmpdir:
        path = Path(tmpdir) / "input.ll"
        path.write_bytes(llvm_ir)
        cmd = ["clang"]
        if emit == "object":
            cmd.append("-c")
        elif emit == "assembly":
            cmd.append("-S")
        cmd.extend([str(path), "-o", "-" if dst is None else str(dst)])
        output = run(cmd, debug=debug)
        if dst is None:
            sys.stdout.buffer.write(output)


def optimize_from_levels(levels: list[str] | None) -> bool:
    if levels is None:
        return False
    return levels[-1] != "0"


def parse_opt_level(level: str) -> str:
    if not level.isdigit():
        raise argparse.ArgumentTypeError("optimization level must be a nonnegative integer")
    return level


def normalize_args(argv: list[str]) -> list[str]:
    result: list[str] = []
    for arg in argv:
        if arg == "-O":
            result.extend(["--opt-level", "1"])
        elif arg.startswith("-O") and arg[2:].isdigit():
            result.extend(["--opt-level", arg[2:]])
        else:
            result.append(arg)
    return result


def main() -> None:
    parser = argparse.ArgumentParser(
        prog="vcc",
        usage="vcc [-h] [-o OUTPUT] [-c | -S | --emit-mlir | --emit-llvm] [-O[N]] source [--debug]",
        description="Compile a C file via VeIR.",
    )
    parser.add_argument("source", type=Path, help="C source file")
    parser.add_argument(
        "-o", "--output",
        help="output path, or - for stdout with non-executable outputs (default: a.out)",
    )
    emit = parser.add_mutually_exclusive_group()
    emit.add_argument(
        "-c", action="store_const", const="object", dest="emit",
        help="emit an object file instead of an executable",
    )
    emit.add_argument(
        "-S", action="store_const", const="assembly", dest="emit",
        help="emit assembly instead of an executable",
    )
    emit.add_argument(
        "--emit-mlir", action="store_const", const="mlir", dest="emit",
        help="emit MLIR instead of an executable",
    )
    emit.add_argument(
        "--emit-llvm", action="store_const", const="llvm", dest="emit",
        help="emit LLVM IR instead of an executable",
    )
    parser.add_argument(
        "--llvm-O2", dest="llvm_o2", action="store_true",
        help="run the full LLVM middle-end (opt -O2) pipeline before mlir-translate",
    )
    parser.add_argument(
        "--opt-level", dest="opt_levels", action="append",
        type=parse_opt_level, metavar="N",
        help=argparse.SUPPRESS,
    )

    parser.add_argument(
        "--debug", action="store_true",
        help="keep tmp files; print commands to stderr",
    )

    parser.epilog = "-O0 disables VeIR optimization; -O and other numeric -O levels run the same optimizer."
    parser.set_defaults(emit="executable", debug=False)
    args = parser.parse_args(normalize_args(sys.argv[1:]))

    if not args.source.is_file():
        sys.exit(f"vcc: source file not found: {args.source}")

    check_tools(BASE_TOOLS + VEIR_TOOLS)

    if args.output == "-":
        if args.emit == "executable":
            sys.exit("vcc: cannot write an executable to stdout")
        dst = None
    elif args.output is not None:
        dst = Path(args.output)
    elif args.emit == "object":
        dst = Path(args.source.stem + ".o")
    elif args.emit == "assembly":
        dst = Path(args.source.stem + ".s")
    elif args.emit == "mlir":
        dst = Path(args.source.stem + ".mlir")
    elif args.emit == "llvm":
        dst = Path(args.source.stem + ".ll")
    else:
        dst = Path("a.out")

    mlir = compile_to_mlir(args.source, optimize_from_levels(args.opt_levels), args.llvm_o2, debug=args.debug)
    if args.emit == "mlir":
        write_output(mlir, dst)
        return

    llvm_ir = translate_mlir_to_llvm(mlir, args.source.stem, debug=args.debug)
    if args.emit == "llvm":
        write_output(llvm_ir, dst)
        return

    finish_llvm_ir(llvm_ir, dst, args.emit, debug=args.debug)


if __name__ == "__main__":
    main()
